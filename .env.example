# ═══════════════════════════════════════════════════════════
#  Vera — Environment Overrides
# ═══════════════════════════════════════════════════════════
#  Copy to .env and adjust values. docker compose reads this
#  automatically. All values shown are the defaults.

# ── Host port mappings (left side of host:container) ─────
# ORCHESTRATOR_PORT=8999
# REDIS_PORT=6379
# POSTGRES_PORT=5433
# CHROMA_PORT=8008
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687

# ── Neo4j credentials ───────────────────────────────────
# NEO4J_USER=neo4j
# NEO4J_PASS=veraneo4j

# ── Ollama cluster (external hosts) ─────────────────────
# OLLAMA_GPU_URL=http://192.168.0.250:11435
# OLLAMA_CPU_A_URL=http://192.168.0.246:11435
# OLLAMA_CPU_B_URL=http://192.168.0.247:11435
# OLLAMA_MODEL=mistral
# OLLAMA_EMBED_URL=http://192.168.0.246:11435
# OLLAMA_EMBED_MODEL=nomic-embed-text

# ── GPU inference (Whisper / TTS / SD) ──────────────────
# GPU_INFER_URL=http://192.168.0.250:8765

# ── Backend network hostname ────────────────────────────
# BACKEND_HOST=llm.int
